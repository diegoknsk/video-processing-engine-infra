    {
      "name": "Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "try {\r",
              "    const r = pm.response.json();\r",
              "\r",
              "    if (r?.success && r?.data?.videoId) {\r",
              "        pm.globals.set(\"videoId\", r.data.videoId);\r",
              "        pm.globals.set(\"uploadUrl\", r.data.uploadUrl);\r",
              "\r",
              "        console.log(\"Video variables set successfully.\");\r",
              "    } else {\r",
              "        console.warn(\"Unexpected response structure.\");\r",
              "    }\r",
              "} catch (e) {\r",
              "    console.error(\"Failed to parse response:\", e);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"originalFileName\": \"Teste.mp4\",\r\n  \"contentType\": \"video/mp4\",\r\n  \"sizeKb\": 15000,\r\n  \"durationSec\": 45,\r\n  \"frameIntervalSec\": 5,\r\n  \"parallelChunks\": 3\r\n}",
